import numpy as np
import matplotlib.pyplot as plt

t=10000  
k=5     
probs=[0.1, 0.3, 0.5, 0.7, 0.2]  
np.random.seed(42)

def run_simulation(algorithm,epsilon=0.1):
    n_pulls=np.zeros(k)    
    sum_rewards=np.zeros(k) 
    regret=np.zeros(t)     
    cumulative_regret=0
    
    if algorithm=="UCB":
        for i in range(k):
            if np.random.rand()<probs[i]:
                reward=1
            else: 
                reward=0    
            n_pulls[i]+=1
            sum_rewards[i]+=reward
            cumulative_regret+=(0.7-probs[i])
            regret[i]=cumulative_regret
        start_t=k
    else:
        start_t=0

    for i in range(start_t,t):
        if algorithm=="Epsilon-Greedy":
            if np.random.rand()<epsilon:
                arm=np.random.choice(k) 
            else:
                arm=np.argmax(sum_rewards/np.maximum(n_pulls,1)) 
        elif algorithm=="UCB":
            average_rewards=sum_rewards/n_pulls
            confidence_interval=np.sqrt(2*np.log(t+1)/n_pulls)
            arm=np.argmax(average_rewards+confidence_interval)
            
        elif algorithm=="Thompson Sampling":
            samples=[np.random.beta(sum_rewards[j]+1,n_pulls[j]-sum_rewards[j]+1) for j in range(k)]
            arm=np.argmax(samples)
        if np.random.rand()<probs[arm]:
            reward=1
        else:
            reward=0
        n_pulls[arm]+=1
        sum_rewards[arm]+=reward
        cumulative_regret+=(0.7-probs[arm])
        regret[i]=cumulative_regret
    return regret

regret_epsilon=run_simulation("Epsilon-Greedy",epsilon=0.1)
regret_ucb=run_simulation("UCB")
regret_ts=run_simulation("Thompson Sampling")

plt.figure(figsize=(10,6))
plt.plot(regret_epsilon,label="$\epsilon$-Greedy ($\epsilon=0.1$)")
plt.plot(regret_ucb,label="UCB")
plt.plot(regret_ts,label="Thompson Sampling")
plt.title("Comparison of Cumulative Regret (t=10000)",fontsize=14)
plt.xlabel("t")
plt.ylabel("Cumulative Regret")
plt.legend()
plt.grid(True,alpha=0.3)
plt.show()
